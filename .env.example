# ─── Sustainability Ministry Portal — Environment Variables ───────────────────
# Copy this file to .env — NEVER commit .env to Git

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram group chat ID (get from @userinfobot in the group)
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Secret key for admin POST endpoints (energy data updates)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=generate_a_long_random_string_here

# Comma-separated list of allowed frontend origins (no trailing slash)
# Set to your GitHub Pages URL once deployed
ALLOWED_ORIGINS=http://localhost:3001,https://YOUR_ORG.github.io

# Server port (default 3001)
PORT=3001

# Google Sheets API key (for live recycling data sync)
# Get from: console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Restrict the key to "Google Sheets API" only
GOOGLE_SHEETS_API_KEY=your_sheets_api_key_here
