# ─── Sustainability Ministry Portal — Environment Variables ───────────────────
# Copy this file to .env — NEVER commit .env to Git

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3001,https://YOUR_ORG.github.io

# Secret key for admin POST endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=generate_a_long_random_string_here

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Set to "true" in production (Railway) to use webhook instead of long-polling
TELEGRAM_USE_WEBHOOK=false

# Random secret to verify webhook calls are from Telegram
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=generate_a_random_string_here

# ─── Supabase (replaces Google Drive / JSON files) ────────────────────────────
# Create a free project at https://supabase.com
# Settings → API → Project URL + service_role key
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=session-images

# ─── Google Sheets (legacy — comment out once migrated to Supabase) ───────────
# GOOGLE_SHEETS_API_KEY=your_sheets_api_key_here
# W2R_SHEET_ID=1ELi47Yq9oPcMqElZGYjWDgnRfS1gVHTwjOseEx5ZPmk
